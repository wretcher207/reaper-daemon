# Runtime working folders — keep the folder, ignore the churn
inbox/*
processing/*
outbox/*
failed/*
archive/*
logs/*
!*/.gitkeep

# Atomic-write temp files
*.tmp

# Bridge runtime state
bridge/heartbeat.json

# Machine-specific config (the bridge regenerates this on first run)
bridge/bridge_config.json

# Editor / agent local settings
.claude/settings.local.json
.DS_Store

# dev test venv for skills
.venvs/

# python bytecode
__pycache__/
*.pyc
.pytest_cache/

# Local Netlify folder
.netlify

# Internal dev notes — kept locally, not shipped in the public repo
MEMORY.md
HANDOFF.md
ERRORS.md
docs/superpowers/

# User drum-kit map overlay (discovered/added maps; not shipped with the repo)
skills/drum-apparatus/maps/*
!skills/drum-apparatus/maps/.gitkeep
